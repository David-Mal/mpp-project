{
  "name": "estethis",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:frontend": "vitest run src/",
    "test:backend": "vitest run backend/api.test.js backend/silver.test.js backend/gold.test.js backend/db.test.js",
    "test:auth": "vitest run backend/auth.test.js backend/session.test.js",
    "test:auth:frontend": "vitest run src/data/auth.test.js src/components/auth.validation.test.js",
    "test:session": "vitest run backend/session.test.js",
    "test:chat": "vitest run backend/chat/chat.test.js",
    "test:action-log": "vitest run backend/actionLog.test.js",
    "test:threats": "vitest run backend/threatDetector.test.js",
    "test:db": "vitest run backend/db.test.js",
    "cert": "node generate-cert.js",
    "start:backend": "node backend/server.js",
    "dev:all": "concurrently \"node backend/server.js\" \"vite\"",
    "migrate": "sequelize-cli db:migrate",
    "migrate:undo": "sequelize-cli db:migrate:undo",
    "migrate:undo:all": "sequelize-cli db:migrate:undo:all"
  },
  "dependencies": {
    "@faker-js/faker": "^9.3.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "graphql": "^16.13.2",
    "graphql-yoga": "^5.21.0",
    "mongoose": "^9.6.2",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sequelize": "^6.37.8",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^2.1.9",
    "@vitest/ui": "^2.0.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "mongodb-memory-server": "^11.1.0",
    "sequelize-cli": "^6.6.5",
