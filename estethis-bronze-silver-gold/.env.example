# ─────────────────────────────────────────────────────────────
# .env.example — copy to .env and fill in your values
#
# The backend (server.js) reads this file via dotenv.
# The Vite dev server reads .env / .env.local automatically.
# ─────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────
# SQLite (default — zero setup, data stored locally)
DB_DIALECT=sqlite
DB_STORAGE=./estethis.sqlite3

# PostgreSQL (production / shared lab DB)
# DB_DIALECT=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=estethis
# DB_USER=postgres
# DB_PASSWORD=changeme

# ── Server ────────────────────────────────────────────────────
# HTTP port (used as a redirect-to-HTTPS port when TLS is active)
PORT=3001
# HTTPS port (primary port when TLS certs are present)
HTTPS_PORT=3443
# Bind address — 0.0.0.0 makes the server reachable from the LAN
HOST=0.0.0.0

# ── TLS / HTTPS ───────────────────────────────────────────────
# Generate a self-signed cert that includes your LAN IP:
#   node generate-cert.js 192.168.x.x
# The cert + key are written to certs/ and picked up automatically.
# If certs/ is missing the server falls back to HTTP.

# ── Session ───────────────────────────────────────────────────
# Inactivity timeout in milliseconds (default: 30 minutes).
# The browser client also tracks inactivity and logs the user out
# client-side after the same period.
SESSION_TIMEOUT_MS=1800000

# ── CORS ──────────────────────────────────────────────────────
# * = allow any origin (safe for a closed LAN lab).
# Set to the exact frontend origin in production:
#   CORS_ORIGIN=https://192.168.1.10:5173
CORS_ORIGIN=*

# ── MongoDB (optional — chat history) ─────────────────────────
# If MongoDB is not running the chat feature falls back to in-memory
# storage (messages are lost on server restart).
MONGO_URI=mongodb://127.0.0.1:27017/estethis_chat

# ─────────────────────────────────────────────────────────────
# Vite dev-server proxy (client-machine .env.local)
# ─────────────────────────────────────────────────────────────
# When the Vite dev server (frontend) runs on a DIFFERENT machine
# than the Express backend, create a .env.local file on the CLIENT
# machine containing:
#
#   BACKEND_HOST=192.168.x.x   ← the server machine's LAN IP
#   BACKEND_PORT=3443          ← omit to use the default
#
# The Vite proxy will forward /api, /ws, and /graphql requests
# to that host.  The self-signed cert must include that IP as a
# Subject Alternative Name (run: node generate-cert.js 192.168.x.x
# on the SERVER machine to regenerate the cert).
