# ── Database ──────────────────────────────────────────────────
# Default: SQLite (zero-config for local dev)
# Switch to postgres for production:
#   DB_DIALECT=postgres
#   DB_HOST=0.0.0.0  (or the server IP)
#   DB_PORT=5432
#   DB_NAME=estethis_db
#   DB_USER=postgres
#   DB_PASSWORD=secret
DB_DIALECT=sqlite
DB_STORAGE=./estethis.sqlite3

# ── Server ─────────────────────────────────────────────────────
PORT=3001
HTTPS_PORT=3443
# 0.0.0.0 binds to all interfaces so devices on the same Wi-Fi network
# can reach the backend at https://<server-ip>:3443.
HOST=0.0.0.0

# ── Session / inactivity timeout ─────────────────────────────
# Auto-logout after this many milliseconds of inactivity (default 30 min).
SESSION_TIMEOUT_MS=1800000

# ── CORS ──────────────────────────────────────────────────────
# * allows all origins; restrict in production, e.g. https://myapp.com
CORS_ORIGIN=*

# ── MongoDB (Step 2 — Chat) ─────────────────────────────
# Install MongoDB Community Edition and start mongod before running.
# If not set or unreachable, chat still works in-memory (no history).
MONGO_URI=mongodb://127.0.0.1:27017/estethis_chat
